<Window x:Class="ƎPIDGRAPH.Views.MainWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ƎPIDGRAPH.ViewModels"
        xmlns:local="clr-namespace:ƎPIDGRAPH.Views"
        x:DataType="vm:MainWindowViewModel"
        Title="ƎPIDGRAPH" Width="1280" Height="720">
    <Grid RowDefinitions="Auto,*" Margin="10">
        <!-- Панель управления -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10">
            <Button Content="Загрузить BBL" Click="OnLoadBblClick" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" />
            <TextBlock Text="Ось:" VerticalAlignment="Center" Margin="20,0,0,0"/>
            <ComboBox ItemsSource="{Binding AxisOptions}"
                      SelectedItem="{Binding SelectedAxis}"
                      Width="120" />
        </StackPanel>

        <!-- Область графика -->
        <Grid x:Name="PlotGrid" Grid.Row="1"
              PointerWheelChanged="OnPointerWheelChanged"
              PointerPressed="OnPointerPressed"
              PointerMoved="OnPointerMoved"
              PointerReleased="OnPointerReleased"
              PointerExited="OnPointerExited">
            <Image x:Name="PlotImage" Stretch="None" />
            <Canvas x:Name="InteractionCanvas" IsHitTestVisible="False">
                <Line x:Name="CrosshairX" Stroke="Gray" StrokeThickness="1" IsVisible="False" />
                <Line x:Name="CrosshairY" Stroke="Gray" StrokeThickness="1" IsVisible="False" />
                <Border x:Name="TooltipBorder" Background="Black"
                        BorderBrush="Black" BorderThickness="1"
                        Padding="4" IsVisible="False" CornerRadius="2">
                    <TextBlock x:Name="TooltipText" FontSize="10" />
                </Border>
            </Canvas>
        </Grid>
    </Grid>
</Window>